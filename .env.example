# Database Configuration
# For SQLite (default, development only)
# DATABASE_URL=sqlite:///pg_finder.db

# For MySQL
DATABASE_URL=mysql+pymysql://root:password@localhost/pg_finder

# For PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost/pg_finder

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your_secret_key_here_change_in_production_with_random_string

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production_with_random_string
JWT_ACCESS_TOKEN_EXPIRES=604800

# Server Configuration
DEBUG=True
PORT=5000
HOST=127.0.0.1

# Email Configuration (for future use)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_email_password

# Payment Gateway (for future use)
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret
